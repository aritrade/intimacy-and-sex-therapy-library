{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["bom1"],
  "github": { "silent": true },
  "functions": {
    "app/api/companion/chat/route.ts": { "maxDuration": 60 },
    "app/api/chat/route.ts": { "maxDuration": 60 },
    "app/api/admin/drafts/route.ts": { "maxDuration": 60 },
    "app/api/admin/drafts/[id]/publish/route.ts": { "maxDuration": 300 },
    "app/api/admin/drafts/[id]/publish-stream/route.ts": { "maxDuration": 300 },
    "app/api/admin/post-metrics/poll/route.ts": { "maxDuration": 60 },
    "app/api/cron/post-metrics-poll/route.ts": { "maxDuration": 60 },
    "app/api/cron/daily-generate/route.ts": { "maxDuration": 300 },
    "app/api/cron/daily-content-sync/route.ts": { "maxDuration": 300 },
    "app/api/health/route.ts": { "maxDuration": 10 },
    "app/api/ready/route.ts": { "maxDuration": 5 }
  },
  "crons": [
    {
      "path": "/api/cron/post-metrics-poll",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/daily-content-sync",
      "schedule": "30 21 * * *"
    }
  ]
}
