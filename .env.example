# =============================================================================
# Intimacy & Sex Therapy Library — environment template
# =============================================================================
#
# Copy this to `.env` for local dev, or paste into Vercel / your platform's
# secret manager for production. Anything left blank is opt-in: the feature
# that depends on it will gracefully refuse rather than crash.
#
# Sections:
#   1. Core (required to boot)
#   2. AI providers
#   3. KMS (envelope encryption for Sahay encrypted-mode sessions)
#   4. Auth.js (Google + Resend magic links)
#   5. Rate limiting
#   6. Short-form content factory (Phase 6)
#   7. Social publishing (manual approval gate; optional)
#   8. Analytics + observability
#   9. Public + compliance metadata
#  10. Admin gate (Basic auth fallback)
#
# Generate any random secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# -----------------------------------------------------------------------------
# 1. Core
# -----------------------------------------------------------------------------

# Postgres 16 with pgvector + pg_trgm. Production: Neon recommended.
# After provisioning, enable extensions ONCE:
#   CREATE EXTENSION IF NOT EXISTS vector;
#   CREATE EXTENSION IF NOT EXISTS pg_trgm;
DATABASE_URL="postgresql://user:password@localhost:5432/sextherapy"

# Node env. Vercel sets this automatically.
NODE_ENV="development"

# Log verbosity: debug | info | warn | error | silent. Default: info in prod.
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# 2. AI providers
# -----------------------------------------------------------------------------

# Choose which LLM powers /chat and /companion. Leave empty to refuse cleanly.
#   "groq"      — Groq cloud (Llama 3.3 70B / Llama 4 / Gemma2). Free tier is
#                 generous; recommended for hosted Vercel deploys where the
#                 laptop-only Ollama path doesn't apply. Tool-calling works
#                 reliably on Llama 3.x and 4.x families.
#   "anthropic" — route to Claude via @ai-sdk/anthropic. Best safety posture.
#   "ollama"    — route everything through a local Ollama daemon (laptop only)
#   ""          — disabled (banner shown on the surfaces, 501 on the APIs)
LLM_PROVIDER=""

# Groq cloud (if LLM_PROVIDER=groq). Get a free key at https://console.groq.com.
# Free tier limits are per-minute (currently 30 req/min, 6000 tokens/min on
# llama-3.3-70b-versatile) which is comfortable for a personal-scale launch.
GROQ_API_KEY=""
# llama-3.3-70b-versatile (default) supports tool-calling. Other Groq models
# you might pick: "llama-3.1-8b-instant" (faster, slightly weaker), or
# "gemma2-9b-it" (cheaper but no tool-calling — chat falls back to inline RAG).
GROQ_MODEL="llama-3.3-70b-versatile"

# Anthropic Claude (if LLM_PROVIDER=anthropic). Also still used by the script-
# generator and adversarial-eval tooling regardless of LLM_PROVIDER, since
# those paths intentionally pin to a frontier model for safety/eval rigor.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

# Local Ollama (if LLM_PROVIDER=ollama). Defaults shown. Only useful for local
# development — the daemon must be reachable from the Next.js process, so
# this path is unavailable on serverless hosts like Vercel.
OLLAMA_HOST="http://127.0.0.1:11434"
OLLAMA_MODEL="gemma4:latest"

# OpenAI — used ONLY for embeddings (text-embedding-3-small) and Whisper STT.
OPENAI_API_KEY=""

# -----------------------------------------------------------------------------
# 3. KMS (envelope encryption)
# -----------------------------------------------------------------------------

# Provider: local | aws.  GCP / Vault adapters can be added later.
KMS_PROVIDER="local"

# Local fallback (DEV ONLY). 32 random bytes, base64-encoded.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KMS_LOCAL_MASTER_KEY=""

# AWS KMS (production). Install the optional dep first:
#   npm install @aws-sdk/client-kms
AWS_REGION=""
AWS_KMS_KEY_ID=""
# Use IAM roles / OIDC where possible. Static keys only in CI:
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Reserved for future adapters
GCP_KMS_KEY_NAME=""
VAULT_TRANSIT_KEY_NAME=""

# -----------------------------------------------------------------------------
# 4. Auth.js
# -----------------------------------------------------------------------------

# REQUIRED if you enable any auth provider. 32+ bytes, base64.
AUTH_SECRET=""

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend magic-link email (https://resend.com)
AUTH_RESEND_KEY=""
AUTH_RESEND_FROM="Intimacy & Sex Therapy Library <noreply@example.com>"

# Auth URL (Vercel sets AUTH_URL automatically; override only if needed)
# AUTH_URL="https://your-domain.example"

# -----------------------------------------------------------------------------
# 5. Rate limiting
# -----------------------------------------------------------------------------

# Upstash Redis (https://upstash.com). If unset, the limiter fails open
# in dev and warns in prod.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# 6. Short-form content factory (Phase 6)
# -----------------------------------------------------------------------------

# Sarvam AI — Hindi / Indic TTS (paid; fallback when Edge TTS isn't ideal).
SARVAM_API_KEY=""

# ElevenLabs — English TTS (paid; fallback for high-stakes voiceovers).
# When set together with ELEVENLABS_VOICE_ID_NARRATOR, used as the
# warm-radio-host voice for the AvatarReel composition.
ELEVENLABS_API_KEY=""
# Default narrator voice id (Rachel — grounded, late-30s timbre).
# See lib/brand/persona.ts for the canonical default.
ELEVENLABS_VOICE_ID_NARRATOR=""

# Stock-footage providers for the StockReel and LongFormEssay templates.
# Both have generous free tiers (Pexels: 200 req/hr, Pixabay: 5K req/hr).
PEXELS_API_KEY=""
PIXABAY_API_KEY=""

# Vercel Blob — required to give the platform publishers a public HTTPS
# URL for the rendered MP4. Free tier covers ~750 MB/month at our cadence.
# Generate at: vercel.com/<team>/<project>/stores -> Create Blob store.
BLOB_READ_WRITE_TOKEN=""

# Replicate.com — hosts the talking-head model (SadTalker by default,
# the most battle-tested still-image lip-sync model on Replicate with
# 169K+ runs). Turns the persona portrait + voiceover into the avatar
# MP4 composited inside the AvatarReel composition. Free signup at
# replicate.com gives ~$5 of credit, enough for hundreds of short
# renders at SadTalker's price (~$0.002 per 30s). Get the token at:
#   https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=""
# Model override. Defaults to cjwbw/sadtalker. Known-good alternatives:
#   - lucataco/sadtalker  (newer fork, same quality)
#   - cjwbw/wav2lip       (different model family; better mouth shapes,
#                          worse head motion)
# When swapping families, ensure lib/social/avatar.ts has a matching
# input-mapping branch in sadTalkerInput().
REPLICATE_AVATAR_MODEL=""
# Hard daily spend cap in USD. Default $2.00. The render pipeline
# refuses avatar generation when today's projected spend would exceed
# this cap; falls back to the existing stock-footage composition so a
# video is always produced.
REPLICATE_MAX_USD_PER_DAY="2.00"
# Per-second cost estimate for the chosen model. SadTalker is roughly
# $0.002/s; Wav2Lip closer to $0.001/s. Used only to project spend
# before submission so the cap can be honoured.
REPLICATE_USD_PER_SECOND="0.002"
# Max wall-clock seconds to wait for a Replicate prediction to finish
# before giving up and falling back to style:"stock". Default 600.
REPLICATE_MAX_WAIT_SECONDS="600"

# -----------------------------------------------------------------------------
# 7. Social publishing (optional, manual approval gate)
# -----------------------------------------------------------------------------

# Instagram (Meta Graph API). Required only if posting Reels.
INSTAGRAM_BUSINESS_ACCOUNT_ID=""
META_GRAPH_ACCESS_TOKEN=""

# YouTube Data API v3 (OAuth installed app, refresh-token flow).
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REFRESH_TOKEN=""

# Optional: a public-data API key for the metrics poller. When set, the
# poller can pull video stats without an OAuth token (read-only).
YOUTUBE_API_KEY=""

# LinkedIn organisation page (cross-poster, optional).
# LINKEDIN_ORG_URN format: urn:li:organization:<numeric-id>
LINKEDIN_ORG_URN=""
LINKEDIN_ACCESS_TOKEN=""

# Twitter / X v2 (cross-poster, optional). Free tier supports text-only
# posts, ~50/day. Use OAuth 1.0a user-context credentials.
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_SECRET=""

# Buttondown email list (welcome-screen signup, optional).
BUTTONDOWN_API_KEY=""

# Auth for the Vercel weekly cron that polls post metrics. Generate a
# random string and paste into BOTH this env var AND Vercel's project env.
# When unset, the cron endpoint refuses with 503.
CRON_SECRET=""

# -----------------------------------------------------------------------------
# 8. Analytics + observability
# -----------------------------------------------------------------------------

# Cookieless analytics (Plausible self-hosted or hosted).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_PLAUSIBLE_HOST=""

# Or Umami (alternative; CSP allows the host below).
NEXT_PUBLIC_UMAMI_HOST=""

# -----------------------------------------------------------------------------
# 9. Public + compliance metadata
# -----------------------------------------------------------------------------

# Public canonical URL (used in sitemap, robots, email links).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# DPDP Act 2023 + GDPR contact strings (rendered on /about/privacy).
NEXT_PUBLIC_DPO_NAME=""
NEXT_PUBLIC_DPO_EMAIL="privacy@example.com"

# -----------------------------------------------------------------------------
# 10. Admin gate
# -----------------------------------------------------------------------------
#
# Two paths into /admin and /api/admin/*:
#
#   Primary (recommended for prod):
#     A signed-in Auth.js session whose user has the `admin` role in
#     `user_roles`. Bootstrap your first admin by listing your email below;
#     the first sign-in will auto-grant the `admin` role and write an audit
#     row tagged `role_bootstrap_admin`.
#
#   Fallback (legacy / ops break-glass):
#     HTTP Basic-auth using ADMIN_BASIC_USER + ADMIN_BASIC_PASS. Disabled by
#     default in prod when these vars are unset. Set ADMIN_BASIC_AUTH_ENABLED=0
#     to FORCE-DISABLE even when creds are set (e.g. once your team is fully
#     migrated to session-based access).
#
# Comma-separated list of emails that auto-receive the `admin` role on
# first sign-in. Idempotent. Production should always set at least one.
BOOTSTRAP_ADMIN_EMAILS=""

# Basic-auth fallback. Leave both blank in prod once you have at least one
# session-based admin. Set ADMIN_BASIC_AUTH_ENABLED=0 to force-disable.
ADMIN_BASIC_USER=""
ADMIN_BASIC_PASS=""
ADMIN_BASIC_AUTH_ENABLED=""
