{
  "name": "sex-therapy-repo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:seed": "tsx scripts/seed-allowlist.ts",
    "db:seed-clinicians": "tsx scripts/seed-clinicians.ts",
    "db:seed-tags": "tsx scripts/seed-tags.ts",
    "db:seed-board": "tsx scripts/seed-board.ts",
    "db:seed-resources": "tsx scripts/seed-resources.ts",
    "db:seed-all": "npm run db:seed && npm run db:seed-tags && npm run db:seed-board && npm run db:seed-clinicians && npm run db:seed-resources",
    "ingest": "tsx scripts/ingest.ts",
    "eval": "tsx scripts/eval.ts",
    "render": "tsx scripts/render-draft.ts",
    "blob:prune": "tsx scripts/prune-render-blobs.ts",
    "blob:prune:dry": "DRY_RUN=1 tsx scripts/prune-render-blobs.ts",
    "archive:drafts": "tsx scripts/archive-posted-drafts.ts",
    "send:digest": "tsx scripts/send-digest.ts",
    "backfill:embeddings": "tsx scripts/backfill-embeddings.ts",
    "seed:corpus": "tsx scripts/seed-corpus.ts",
    "dedupe:chunks": "tsx scripts/dedupe-chunks.ts",
    "remotion:studio": "remotion studio video-factory/index.ts",
    "social:pull-metrics": "tsx scripts/pull-post-metrics.ts",
    "preflight": "tsx scripts/preflight.ts",
    "preflight:strict": "tsx scripts/preflight.ts --strict",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@auth/drizzle-adapter": "^1.11.2",
    "@aws-sdk/client-sesv2": "^3.1062.0",
    "@remotion/bundler": "^4.0.465",
    "@remotion/captions": "^4.0.465",
    "@remotion/cli": "^4.0.465",
    "@remotion/renderer": "^4.0.465",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "ai": "^4.0.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "ffmpeg-static": "^5.3.0",
    "msedge-tts": "^2.0.5",
    "next": "14.2.18",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "ollama-ai-provider": "^1.2.0",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "remotion": "^4.0.465",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.19.19",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
